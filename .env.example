# Tenderhook environment — see TOOLS.md for the full table.
# Copy to .env (gitignored). Never commit real values.

# Postgres (local compose default)
DATABASE_URL=postgres://tenderhook:tenderhook@localhost:5432/tenderhook

# Document blob store (S3/R2) — not required for M1 (fixtures only)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Per-customer SLED portal credential envelope key — not required for M1
CREDENTIALS_ENCRYPTION_KEY=

# External APIs — all optional in M1; the pipeline runs on checked-in fixtures
# and a deterministic mock summarizer when keys are absent.
SAM_GOV_API_KEY=
TED_API_KEY=
VOYAGE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
RESEND_API_KEY=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
